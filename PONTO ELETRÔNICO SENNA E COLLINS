<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Ponto Eletrônico</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 50px; background-color: #f4f4f9; }
        #relogio { font-size: 3em; color: #333; margin-bottom: 20px; }
        button { padding: 20px 40px; font-size: 1.5em; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 10px; }
        ul { list-style: none; padding: 0; margin-top: 20px; }
        li { background: white; padding: 10px; margin: 5px auto; width: 300px; border: 1px solid #ddd; border-radius: 5px; }
    </style>
</head>
<body>
    <h1>Meu Ponto</h1>
    <div id="relogio">00:00:00</div>
    <button onclick="baterPonto()">Registrar Ponto</button>
    <h3>Histórico:</h3>
    <ul id="historico"></ul>

    <script>
        setInterval(() => {
            document.getElementById('relogio').innerText = new Date().toLocaleTimeString();
        }, 1000);

        function atualizarLista() {
            const historico = JSON.parse(localStorage.getItem('pontos') || '[]');
            const ul = document.getElementById('historico');
            ul.innerHTML = historico.map(p => `<li>${p}</li>`).join('');
        }
        
        function baterPonto() {
            const agora = new Date().toLocaleString();
            let historico = JSON.parse(localStorage.getItem('pontos') || '[]');
            historico.push(agora);
            localStorage.setItem('pontos', JSON.stringify(historico));
            atualizarLista();
        }

        atualizarLista();
    </script>
</body>
</html>
